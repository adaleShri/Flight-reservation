pipeline {
    agent any
    
    environment {
        DOCKER_REGISTRY = 'adaleshri'
        DOCKER_IMAGE_NAME = 'flight-checkin-app'
        DOCKER_IMAGE_TAG = "${BUILD_NUMBER}"
        MAVEN_HOME = tool 'Maven'
        JAVA_HOME = tool 'jdk17'
        SONAR_HOST_URL = 'http://13.233.151.142:9000'
        SONAR_TOKEN = credentials('sonar-token')
        APP_DIR = 'FlightReservationApplication'
    }
    
    stages {
        
        stage('PULL') {
            steps {
                checkout scm
            }
        }
        
        stage('BUILD') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        ${MAVEN_HOME}/bin/mvn clean package -DskipTests
                    '''
                }
            }
        }
        
        stage('QA Test') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        ${MAVEN_HOME}/bin/mvn test
                    '''
                }
            }
            post {
                always {
                    junit "${APP_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                dir("${APP_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            ${MAVEN_HOME}/bin/mvn sonar:sonar \
                            -Dsonar.projectKey=flight-checkin-app \
                            -Dsonar.java.binaries=target/classes \
                            -Dsonar.sources=src/main/java \
                            -Dsonar.tests=src/test/java \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                            -Dsonar.host.url=${SONAR_HOST_URL} \
                            -Dsonar.login=${SONAR_TOKEN}
                        '''
                    }
                }
            }
        }
        
        stage('DOCKER BUILD') {
            steps {
                dir("${APP_DIR}") {
                    script {
                        docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG}")
                    }
                }
            }
        }
        
        stage('DOCKER PUSH') {
            steps {
                script {
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-creds') {
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG}").push()
                    }
                }
            }
        }
        
        stage('DOCKER DEPLOY') {
            steps {
                sh '''
                echo "Stopping old container..."
                docker stop flight-checkin-app || true
                docker rm flight-checkin-app || true

                echo "Pulling latest image..."
                docker pull ${DOCKER_REGISTRY}/${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG}

                echo "Running new container..."
                docker run -d \
                  -p 8080:8080 \
                  --name flight-checkin-app \
                  --restart always \
                  ${DOCKER_REGISTRY}/${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG}
                '''
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}
