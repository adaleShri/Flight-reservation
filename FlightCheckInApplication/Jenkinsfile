pipeline {
    agent any
    
    environment {
        DOCKER_REGISTRY = 'adaleshri/flight-checkin-app'
        DOCKER_IMAGE_NAME = 'flight-checkin-app'
        MAVEN_HOME = tool 'Maven'
        JAVA_HOME = tool 'jdk17'
        SONAR_HOST_URL = 'http://13.233.151.142:9000'
        SONAR_TOKEN = credentials('sonar-token')
        APP_DIR = 'FlightReservationApplication'
    }
    
    stages {
        
        stage('PULL') {
            steps {
                checkout scm
            }
        }
        
        stage('BUILD') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        ${MAVEN_HOME}/bin/mvn clean package -DskipTests
                    '''
                }
            }
        }
        
        stage('QA Test') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        ${MAVEN_HOME}/bin/mvn test
                    '''
                }
            }
            post {
                always {
                    junit "${APP_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                dir("${APP_DIR}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            ${MAVEN_HOME}/bin/mvn sonar:sonar \
                            -Dsonar.projectKey=flight-checkin-app \
                            -Dsonar.java.binaries=target/classes \
                            -Dsonar.sources=src/main/java \
                            -Dsonar.tests=src/test/java \
                            -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml \
                            -Dsonar.host.url=${SONAR_HOST_URL} \
                            -Dsonar.login=${SONAR_TOKEN}
                        '''
                    }
                }
            }
        }
        
        stage('DOCKER BUILD') {
            steps {
                dir("${APP_DIR}") {
                script {
                    docker.build("${DOCKER_REGISTRY}/${DOCKER_IMAGE_NAME}:LATEST")
                }
            }
        }
        
        stage('DOCKER PUSH') {
            steps {
                script {
                    docker.withRegistry("https://${DOCKER_REGISTRY}", 'docker-creds') {
                        docker.image("${DOCKER_REGISTRY}/${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG}").push()
                    }
                }
            }
        }
        
        stage('DEPLOY') {
            steps {
                sh '''
                    kubectl set image deployment/flight-checkin-app \
                    flight-checkin-app=${DOCKER_REGISTRY}/${DOCKER_IMAGE_NAME}:${DOCKER_IMAGE_TAG} \
                    --namespace=flight-checkin
                '''
            }
        }
    }
    
    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            cleanWs()
        }
    }
}

